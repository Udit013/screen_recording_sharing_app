# ─── Database (Neon PostgreSQL - free tier at neon.tech) ──────────────────────
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── Auth (better-auth) ───────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-here
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Create at console.cloud.google.com → APIs & Services → Credentials
# Redirect URI: {NEXT_PUBLIC_BASE_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── Cloudinary (free tier at cloudinary.com - no CC required) ───────────────
# Get from cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name

# ─── AI Features (optional - free at aistudio.google.com) ────────────────────
# Leave blank to disable AI summary / tag features
GEMINI_API_KEY=
