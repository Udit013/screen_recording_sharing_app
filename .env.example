# ──────────────────────────────────────────────────────────────
#  SnapCast — Environment Variables
#  Copy this file to .env.local and fill in all values.
#  NEVER commit .env.local to git.
# ──────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────
# Your deployed URL (no trailing slash). Use http://localhost:3000 for dev.
NEXT_PUBLIC_BASE_URL=https://your-app.vercel.app

# ── Database (Neon PostgreSQL — free tier) ────────────────────
# Sign up at https://neon.tech → New Project → copy the connection string.
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://...

# ── Google OAuth ──────────────────────────────────────────────
# https://console.cloud.google.com → Credentials → OAuth 2.0 Client IDs
# Authorized redirect URI: {NEXT_PUBLIC_BASE_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Better Auth ───────────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# ── Bunny.net ─────────────────────────────────────────────────
# Dashboard → Stream → Library → API → Access Key
BUNNY_LIBRARY_ID=
BUNNY_STREAM_ACCESS_KEY=

# Dashboard → Storage → Storage Zone → FTP & API Access → Password
BUNNY_STORAGE_ACCESS_KEY=

# Your storage zone endpoint (e.g. https://sg.storage.bunnycdn.com/your-zone)
BUNNY_STORAGE_ZONE_URL=https://sg.storage.bunnycdn.com/your-zone

# Your CDN pull-zone URL (e.g. https://your-zone.b-cdn.net)
BUNNY_CDN_URL=https://your-zone.b-cdn.net

# Bunny transcript CDN base URL (e.g. https://vz-xxxxxx.b-cdn.net)
# Leave empty to disable auto-transcript fetching.
BUNNY_TRANSCRIPT_BASE_URL=

# Bunny Library ID exposed to the client for iframe embed URLs
NEXT_PUBLIC_BUNNY_LIBRARY_ID=

# ── Arcjet (Security — free tier) ────────────────────────────
# Sign up at https://arcjet.com → New Application → copy the key
ARCJET_API_KEY=

# ── Gemini AI (free tier) ─────────────────────────────────────
# Sign up at https://aistudio.google.com → Get API key
# Free tier: 15 RPM, 1M tokens/day — more than enough.
# Leave empty to disable AI features (app still works without it).
GEMINI_API_KEY=
